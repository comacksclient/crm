// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(SDR)
  team_id   String? // The explicit corporate team this user was assigned to
  team      Team?    @relation(fields: [team_id], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id        String       @id @default(uuid())
  name      String       @unique // e.g. "Alpha Squad"
  users     User[] // Members in this team
  leads     Lead[] // Loads delegated to this team
  invites   TeamInvite[] // Outstanding invite links for this team
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TeamInvite {
  id        String   @id @default(uuid())
  team_id   String
  team      Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)
  createdBy String // ID of the Manager/Admin who generated this link
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  SDR
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Lead {
  id              String @id @default(uuid())
  lead_identity   String // Clinic - Location - Phone
  assignment_info String // City/Manager assignment

  // Explicit Lead Identity
  lead_code    String?
  clinic_name  String?
  phone_number String?
  city         String?

  lead_type String? // New / Hot / Nurture / Cold

  // Call Qualification
  call_outcome   String?
  doctor_type    String?
  interest_level Int?
  call_notes     String?

  // Automated Follow-Ups
  next_action_type      String? @default("New")
  whatsapp_details_sent Boolean @default(false)
  next_action_date      String? // Formatted YYYY-MM-DD
  last_call_date        String?
  touch_count           Int     @default(0)

  // State Management
  lead_status    String  @default("Active") // Active, Meeting Booked, Disqualified
  priority_score Int     @default(0)
  overdue        Boolean @default(false)

  // Meeting Booking Fields
  meeting_status Boolean @default(false)
  meeting_date   String?
  meeting_time   String?

  // Relations
  team_id       String? // The high-level Team (e.g. "Alpha Squad") assigned to work these leads
  team          Team?     @relation(fields: [team_id], references: [id])
  manager_id    String? // Manager who actively checked up on or routed this lead
  sdr_id        String? // The explicitly assigned caller who must execute the call
  assigned_to   String? // Text definition of assignment
  assigned_date String?
  meetings      Meeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Meeting {
  id      String @id @default(uuid())
  lead_id String
  lead    Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  // Lead Snapshot
  clinic_name  String?
  phone_number String?

  meeting_date   String
  meeting_time   String
  meeting_status String  @default("Scheduled") // Scheduled, Completed, No Show, Rescheduled, Cancelled
  booked_by      String // SDR name/email who booked it
  meeting_notes  String?
  no_show        Boolean @default(false)

  // Reschedule Tracking
  rescheduled_from String?
  rescheduled_to   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
